# ──────────────────────────────────────────────────────────
# backend/.env.example
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/lifelink?retryWrites=true&w=majority

# JWT Secrets (generate strong random strings)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_different_from_above
JWT_REFRESH_EXPIRES_IN=30d

# Firebase Admin SDK
# Get from: Firebase Console → Project Settings → Service Accounts → Generate New Key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADA...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Cloudinary
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=abcdef1234567890abcdef1234

# Email (Gmail SMTP)
# Enable 2FA then generate App Password: myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Client URL (your deployed frontend)
CLIENT_URL=http://localhost:3000

# Rate limiting (optional overrides)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
