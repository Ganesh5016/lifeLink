# ──────────────────────────────────────────
# LifeLink – .gitignore
# ──────────────────────────────────────────

# Environment files — NEVER commit these
**/.env
**/.env.local
**/.env.production
**/.env.development
**/google-services.json
**/GoogleService-Info.plist

# Dependencies
**/node_modules/
**/.pnp
**/.pnp.js

# Build outputs
frontend/.next/
frontend/out/
mobile/.expo/
mobile/dist/
backend/dist/

# Logs
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Testing
**/coverage/
**/.nyc_output

# Misc
**/.cache/
**/tmp/
**/temp/
